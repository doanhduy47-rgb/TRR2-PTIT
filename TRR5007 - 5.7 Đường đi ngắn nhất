#include<bits/stdc++.h>
using namespace std;

const int INF = 1e9;

int n, s, t, par[105];

struct edge{
    int u, v, w;
};

vector<edge> e;

void nhap(){
    cin >> n >> s >> t;

    for(int i = 1; i <= n; i++){
        for(int j = 1; j <= n; j++){
            int w;
            cin >> w;

            if(w != 10000 && i != j){
                e.push_back({i, j, w});
            }
        }
    }
}

void bellman(int s){
    vector<int> d(n+1, INF);

    for(int i=1;i<=n;i++) par[i] = i;

    d[s] = 0;

    for(int i = 1; i <= n-1; i++){
        for(auto it : e){
            int u = it.u;
            int v = it.v;
            int w = it.w;

            if(d[u] != INF && d[v] > d[u] + w){
                d[v] = d[u] + w;
                par[v] = u;
            }
        }
    }

    // check negative cycle (nếu có)
    for(auto it : e){
        int u = it.u;
        int v = it.v;
        int w = it.w;

        if(d[u] != INF && d[v] > d[u] + w){
            cout << -1 << endl;
            return;
        }
    }

    if(d[t] == INF){
        cout << 0 << endl;
        return;
    }

    cout << d[t] << endl;

    vector<int> path;
    int cur = t;

    while(par[cur] != cur){
        path.push_back(cur);
        cur = par[cur];
    }
    path.push_back(s);

    reverse(path.begin(), path.end());

    for(int x : path) cout << x << ' ';
}
 
int main(){
    freopen("BN.INP","r",stdin);
    freopen("BN.OUT","w",stdout);

    nhap();
    bellman(s);
}
