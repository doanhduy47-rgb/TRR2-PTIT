#include <bits/stdc++.h>
using namespace std;

#define ll long long
#define ii pair<int, int>

const ll INF = 1e18;

int n, s, t;
int par[105];
vector<ii> adj[105];

void nhap() {
    cin >> n >> s >> t;

    for (int i = 1; i <= n; i++) {
        for (int j = 1; j <= n; j++) {
            int w;
            cin >> w;

            if (w > 0 && w <= 50) {
                adj[i].push_back({j, w});
            }
        }
    }
}

void dijkstra(int s) {
    vector<ll> d(n + 1, INF);

    for (int i = 1; i <= n; i++) {
        par[i] = -1;
    }

    d[s] = 0;

    priority_queue<
        pair<ll, int>,
        vector<pair<ll, int>>,
        greater<pair<ll, int>>
    > q;

    q.push({0, s});

    while (!q.empty()) {
        pair<ll, int> top = q.top();
        q.pop();

        ll kc = top.first;
        int u = top.second;

        if (kc > d[u]) continue;

        for (auto it : adj[u]) {
            int v = it.first;
            int w = it.second;

            if (d[v] > d[u] + w) {
                d[v] = d[u] + w;
                par[v] = u;
                q.push({d[v], v});
            }
        }
    }

    if (d[t] == INF) {
        cout << 0;
        return;
    }

    cout << d[t] << '\n';

    vector<int> path;

    for (int v = t; v != -1; v = par[v]) {
        path.push_back(v);
    }

    reverse(path.begin(), path.end());

    for (int x : path) {
        cout << x << ' ';
    }
}

int main() {
    freopen("DN.INP", "r", stdin);
    freopen("DN.OUT", "w", stdout);

    nhap();
    dijkstra(s);

    return 0;
}
